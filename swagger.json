{
  "openapi": "3.0.0",
  "paths": {
    "/billing/check-billing": {
      "get": {
        "description": "This endpoint returns the current billing status, indicating whether billing is currently running.",
        "operationId": "BillingController_currentStatus",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current billing status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "isBillingRunning": true
                  }
                }
              }
            }
          }
        },
        "summary": "Get Current Billing Status",
        "tags": [
          "Billing"
        ]
      }
    },
    "/reports": {
      "get": {
        "description": "Returns a list of reports.",
        "operationId": "ReportsController_list",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Page number",
            "schema": {
              "minimum": 0,
              "default": 0,
              "example": 0,
              "type": "number"
            }
          },
          {
            "name": "pageSize",
            "required": false,
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 10,
              "example": 10,
              "type": "number"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Search term for UC, meter point, or nickname (case-insensitive contains)",
            "schema": {
              "example": "SP",
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "description": "Filter by status (can be multiple). Accepts array or comma-separated values. Example: ?status=SENT&status=READY_TO_SEND or ?status=SENT,READY_TO_SEND",
            "schema": {
              "example": [
                "READY_TO_GENERATE",
                "SENT"
              ],
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "READY_TO_GENERATE",
                  "GENERATING_REPORT",
                  "PENDING_INFORMATION",
                  "NEED_ANALYSIS",
                  "PROCESSING_ERROR",
                  "READY_TO_SEND",
                  "QUEUED_FOR_SENDING",
                  "SENT",
                  "SENDING_ERROR"
                ]
              }
            }
          },
          {
            "name": "startDate",
            "required": false,
            "in": "query",
            "description": "Start date for filtering reports",
            "schema": {
              "example": "2026-01-01",
              "type": "string"
            }
          },
          {
            "name": "endDate",
            "required": false,
            "in": "query",
            "description": "End date for filtering reports",
            "schema": {
              "example": "2026-02-01",
              "type": "string"
            }
          },
          {
            "name": "economicGroup",
            "required": false,
            "in": "query",
            "description": "Filter by economic group",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "orderBy",
            "required": false,
            "in": "query",
            "description": "Sort by field",
            "schema": {
              "default": "referenceDate",
              "example": "referenceDate",
              "type": "string",
              "enum": [
                "referenceDate",
                "codeUc",
                "nickname",
                "economicGroup",
                "reportStatus",
                "updatedAt"
              ]
            }
          },
          {
            "name": "order",
            "required": false,
            "in": "query",
            "description": "Sort order",
            "schema": {
              "default": "desc",
              "example": "desc",
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved reports list"
          }
        },
        "summary": "List Reports",
        "tags": [
          "reports"
        ]
      }
    },
    "/reports/summary": {
      "get": {
        "description": "Returns a summary of reports for a given reference date.",
        "operationId": "ReportsController_summary",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successfully retrieved report summary"
          }
        },
        "summary": "Report Summary",
        "tags": [
          "reports"
        ]
      }
    },
    "/reports/{correlationId}/versions": {
      "get": {
        "description": "Returns the mocked list of versions for a specific report correlationId.",
        "operationId": "ReportsController_versions",
        "parameters": [
          {
            "name": "correlationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved report versions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportVersionsResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "Report not found"
          }
        },
        "summary": "List report versions by correlationId",
        "tags": [
          "reports"
        ]
      }
    },
    "/reports/generate": {
      "post": {
        "description": "Triggers the generation of reports and sends them to the processing queue.",
        "operationId": "ReportsController_generate",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Reports generation initiated successfully"
          }
        },
        "summary": "Generate Reports",
        "tags": [
          "reports"
        ]
      }
    },
    "/reports/{correlationId}/generate": {
      "post": {
        "description": "Triggers the generation of a report for a specific correlationId and sends it to the processing queue.",
        "operationId": "ReportsController_generateByCorrelationId",
        "parameters": [
          {
            "name": "correlationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Report generation initiated successfully"
          }
        },
        "summary": "Generate Report by correlationId",
        "tags": [
          "reports"
        ]
      }
    },
    "/files/{correlationId}": {
      "get": {
        "description": "Returns file metadata for a given report correlationId.",
        "operationId": "FilesController_getFile",
        "parameters": [
          {
            "name": "correlationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved file info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        },
        "summary": "Get file info by correlation ID",
        "tags": [
          "files"
        ]
      }
    },
    "/files/{correlationId}/download": {
      "get": {
        "description": "Returns the binary PDF file for a given report correlationId.",
        "operationId": "FilesController_downloadFile",
        "parameters": [
          {
            "name": "correlationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully downloaded file"
          },
          "404": {
            "description": "File not found"
          }
        },
        "summary": "Download file by correlation ID",
        "tags": [
          "files"
        ]
      }
    },
    "/health/check-billing": {
      "get": {
        "description": "Returns information about the current billing process, including whether it is running, current reference date, and last billing event timestamp.",
        "operationId": "HealthController_checkBilling",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successfully retrieved billing status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckBillingResponseDto"
                }
              }
            }
          }
        },
        "summary": "Check billing process status",
        "tags": [
          "health"
        ]
      }
    },
    "/health/check-generation-reports": {
      "get": {
        "description": "Returns information about the report generation process, including number of reports being generated, queued to generate, and current reference date.",
        "operationId": "HealthController_checkGenerationReports",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successfully retrieved generation status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckGenerationReportsResponseDto"
                }
              }
            }
          }
        },
        "summary": "Check report generation status",
        "tags": [
          "health"
        ]
      }
    }
  },
  "info": {
    "title": "Matrix Reports API",
    "description": "API for managing energy reports with pagination and filters",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Billing",
      "description": "Billing endpoints"
    },
    {
      "name": "files",
      "description": "Files endpoints"
    },
    {
      "name": "health",
      "description": "Health check endpoints"
    },
    {
      "name": "reports",
      "description": "Reports management endpoints"
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "ReportVersionsResponseDto": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": "string",
            "description": "Correlation ID of the report",
            "example": "mock-correlation-000001"
          },
          "versions": {
            "description": "List of versions available for the report",
            "example": [
              "1.0.0"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "correlationId",
          "versions"
        ]
      },
      "FileResponseDto": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "description": "Name of the generated report file",
            "example": "relatorio-uc-sp-000001-2026-03.pdf"
          },
          "downloadUrl": {
            "type": "string",
            "description": "Public URL used to download the file",
            "example": "https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf"
          },
          "createdBy": {
            "type": "string",
            "description": "User or process that generated the file",
            "example": "mock.api"
          },
          "updatedAt": {
            "type": "string",
            "description": "Last file update timestamp",
            "example": "2026-03-26T12:00:00.000Z"
          }
        }
      },
      "CheckBillingResponseDto": {
        "type": "object",
        "properties": {
          "isBillingRunning": {
            "type": "boolean",
            "example": true,
            "description": "Whether billing process is currently running"
          },
          "currentReferenceDate": {
            "type": "string",
            "example": "02/2026",
            "description": "Current reference month/year (MM/YYYY)"
          },
          "lastBillingEventAt": {
            "type": "string",
            "example": "2026-02-04T10:30:00.000Z",
            "description": "Timestamp of last billing event"
          },
          "message": {
            "type": "string",
            "example": "Billing process is active with reports being generated"
          }
        },
        "required": [
          "isBillingRunning",
          "currentReferenceDate",
          "lastBillingEventAt",
          "message"
        ]
      },
      "CheckGenerationReportsResponseDto": {
        "type": "object",
        "properties": {
          "isGeneratingReports": {
            "type": "boolean",
            "example": true,
            "description": "Whether reports are currently being generated"
          },
          "generatingCount": {
            "type": "number",
            "example": 5,
            "description": "Number of reports with status GENERATING_REPORT"
          },
          "queuedToGenerate": {
            "type": "number",
            "example": 31,
            "description": "Number of reports with status READY_TO_GENERATE"
          },
          "currentReferenceDate": {
            "type": "string",
            "example": "02/2026",
            "description": "Current reference month/year (MM/YYYY)"
          }
        },
        "required": [
          "isGeneratingReports",
          "generatingCount",
          "queuedToGenerate",
          "currentReferenceDate"
        ]
      }
    }
  }
}